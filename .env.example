DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_client_id

# Optional: set this for faster command registration during development.
DISCORD_GUILD_ID=your_test_server_id

# Optional: defaults to data/giberrator.sqlite.
GIBERRATOR_DB_PATH=data/giberrator.sqlite

# Required for the translation service.
OLLAMA_MODEL=llama3.2

# Optional: defaults to http://localhost:11434 when running locally.
# For Docker, docker-compose.yml defaults this to http://host.docker.internal:11434
# and maps host.docker.internal to the host gateway.
# OLLAMA_BASE_URL=http://localhost:11434

# Optional: defaults to 30000.
OLLAMA_TIMEOUT_MS=30000

# Optional: defaults to prompts/ungibberish-system.txt.
UNGIBBERISH_PROMPT_PATH=prompts/ungibberish-system.txt

# Optional: defaults to 100 queued Discord messages.
TRANSLATION_QUEUE_MAX_SIZE=100
